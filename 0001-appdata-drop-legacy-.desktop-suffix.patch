From 3d8591130a7f905e2c4545100cafbd9f1e1996c2 Mon Sep 17 00:00:00 2001
From: Harald Sitter <sitter@kde.org>
Date: Wed, 17 Jun 2026 16:54:15 +0200
Subject: [PATCH] appdata: drop legacy .desktop suffix

mark the old name as provided for backwards compat
---
 org.kde.audex.appdata.xml | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/org.kde.audex.appdata.xml b/org.kde.audex.appdata.xml
index 29aebf3..f3bde3c 100644
--- a/org.kde.audex.appdata.xml
+++ b/org.kde.audex.appdata.xml
@@ -1,6 +1,6 @@
 <?xml version="1.0" encoding="utf-8"?>
 <component type="desktop">
-  <id>org.kde.audex.desktop</id>
+  <id>org.kde.audex</id>
   <metadata_license>FSFAP</metadata_license>
   <project_license>GPL-2.0</project_license>
   <name>Audex</name>
@@ -163,6 +163,7 @@
   </developer>
   <provides>
     <binary>audex</binary>
+    <id>org.kde.audex.desktop</id>
   </provides>
   <launchable type="desktop-id">org.kde.audex.desktop</launchable>
   <releases>
